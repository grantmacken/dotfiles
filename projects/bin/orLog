  grep  -oP  '^.+\[lua\]\s\K([\w-_]+\.lua.+)(?=,\sclient)' |
  tail |
  awk -v user="$FILE_PATH" 'BEGIN { FS = ":" } ;{printf("%s:%s:I: [%s ]%s\n",user$1,$2,$3,$4,$5)}'

