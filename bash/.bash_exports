# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ] ; then
    PATH="$HOME/bin:$PATH"
fi
# set PATH so it includes user's projects bin if it exists
export BASE_SESSION="$(git config user.name)"
if [ -n "${BASE_SESSION}" ] ; then
    export PROJECTS="$HOME/projects/${BASE_SESSION}"
 if [ -d "$PROJECTS/bin" ] ; then
        [[ $PATH == ?(*:)$PROJECTS/bin?(:*) ]] || PATH="$PROJECTS/bin:$PATH"
    fi
    if [ -d "$PROJECTS/node_modules/.bin" ] ; then
     [[ $PATH == ?(*:)$PROJECTS/node_modules/.bin?(:*) ]] || PATH="$PROJECTS/node_modules/.bin:$PATH"
 fi
fi

# Make nvim the default editor
export EDITOR="nvim"
export MANPAGER="nvim -c 'set ft=man' -"

export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
# export NVIM_LISTEN_ADDRESS=/tmp/nvimsocket

#export FZF_DEFAULT_COMMAND='ag -g ""'
# To apply the command to CTRL-T as well
#export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
export HISTSIZE=32768
export HISTFILESIZE=$HISTSIZE

# don't put duplicate lines or lines starting with space in the history.
export HISTCONTROL=ignoreboth

# Make some commands not show up in history
export HISTIGNORE="ls:cd:cd -:pwd:exit:date:* --help"

# Prefer US English and use UTF-8
export LANG="en_US"
export LC_ALL="en_US.UTF-8"

# Highlight section titles in manual pages
export LESS_TERMCAP_md="$ORANGE"

# openpesty nginx
OPENRESTY_HOME=/usr/local/openresty
NGINX_HOME=${OPENRESTY_HOME}/nginx
export PATH=${OPENRESTY_HOME}/bin:${OPENRESTY_HOME}/luajit/bin:$PATH

# saxon and expath repo
export PATH="/usr/local/expath/pkg/bin:$PATH"
export EXPATH_REPO="/usr/local/expath/repo"
export SAXON_HOME="/usr/local/expath/pkg/saxon"


export PATH="$HOME/.linuxbrew/bin:$PATH"
export MANPATH="$HOME/.linuxbrew/share/man:$MANPATH"
export INFOPATH="$HOME/.linuxbrew/share/info:$INFOPATH"

## Add these commands to your shell initialization:
export PATH=~/.bpan/bin:~/.bpan/lib:"$PATH"
export MANPATH=~/.bpan/man:"$MANPATH"

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"  # This loads nvm
# added by travis gem
[ -f $HOME/.travis/travis.sh ] && source $HOME/.travis/travis.sh
[ -f $HOME/projects/ingydotnet/git-subrepo/init ] && source $HOME/projects/ingydotnet/git-subrepo/init

